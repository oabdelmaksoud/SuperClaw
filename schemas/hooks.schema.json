{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenClaw Hook Intent Configuration",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "profile": {
      "type": "string",
      "enum": ["minimal", "standard", "strict"]
    },
    "events": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "intent", "mappedAction"],
          "properties": {
            "id": { "type": "string" },
            "intent": { "type": "string" },
            "mappedAction": { "type": "string" }
          }
        }
      }
    }
  },
  "required": ["profile", "events"]
}
