{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Plugin Pack Metadata",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "roles": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
